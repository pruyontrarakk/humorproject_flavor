# Supabase (browser + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Caption API (optional)
#
# If unset, the app defaults to Almost Crack’d staging:
#   POST https://api.almostcrackd.ai/pipeline/generate-captions
#   Body: { "imageId": "<images.id>" }
#   Header: Authorization: Bearer <Supabase access_token>
# (Same contract as humorproject/app/upload/page.tsx after image registration.)
#
# Set CAPTION_API_URL to your own endpoint to send instead:
#   { image_url, humor_flavor_id, steps: [...] }
# Optional Bearer for that mode:
CAPTION_API_URL=
CAPTION_API_KEY=

# Aliases (optional)
# ALMOST_CRACKD_CAPTION_URL=
# ALMOST_CRACKD_API_KEY=
